{
  "name": "you-bot-ai",
  "version": "1.0.0",
  "description": "Your Personal Offline AI System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd app/frontend && npm run dev",
    "dev:backend": "cd app/backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd app/frontend && npm run build",
    "build:backend": "cd app/backend && npm run build",
    "start": "cd app/backend && npm start",
    "start:local": "./scripts/start-local.sh",
    "build:pwa": "./scripts/build-pwa.sh",
    "install:models": "./scripts/install-models.sh",
    "clean:cache": "./scripts/clean-cache.sh"
  },
  "keywords": ["ai", "local-ai", "pwa", "offline", "llama", "nodejs"],
  "author": "Aung Myo Kyaw",
  "license": "MIT"
}